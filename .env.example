# Copy this file to .env and fill in real values.
# Never commit .env — it is in .gitignore.

# ── Required ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── RAG settings (all prefixed RAG_) ─────────────────────────────────────────
RAG_REDIS_URL=redis://localhost:6379
RAG_HNSW_PATH=data/hnsw.index
RAG_HNSW_EF_SEARCH=64

# Auth: leave RAG_DB_URL empty to use the env-dict below for local dev.
# Set it to a Postgres DSN in production (keys are then stored in the DB).
RAG_DB_URL=

# Local dev only — a JSON map of raw-token -> tenant-id.
# In production this is replaced by Postgres api_keys table; this env var is ignored
# when RAG_DB_URL is set.
RAG_TENANT_TOKENS={"your-local-dev-token": "dev"}

# ── Deploy (only needed for Terraform / GitHub Actions) ───────────────────────
HCLOUD_TOKEN=your-hetzner-cloud-api-token
